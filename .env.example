# --- DATABASE ---
DATABASE_URL="postgres://postgres:password@localhost:5433/vidforge"

# --- APIs & URL ---
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# --- AUTHENTICATION (JWT & NextAuth) ---
# Generate a strong secret via: openssl rand -base64 32
JWT_SECRET="vidforge-super-secret-jwt-key-change-me-in-production"
JWT_EXPIRES_IN="7d"

# NextAuth Secret
AUTH_SECRET="vidforge-super-secret-jwt-key-change-me-in-production"
AUTH_URL="http://localhost:3000"

# --- SYSTEM SETTINGS ---
# The email address of the super admin
ADMIN_EMAIL="tunganht26@gmail.com"

# --- GOOGLE CLOUD CONSOLE (Storage & Auth) ---
# 1. Google Storage (For Video/Image Assets)
GOOGLE_CLOUD_PROJECT_ID="your-google-cloud-project-id"
GOOGLE_CLOUD_CLIENT_EMAIL="your-service-account-email@your-project.iam.gserviceaccount.com"
GOOGLE_CLOUD_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
GOOGLE_CLOUD_BUCKET_NAME="vidforge-video-assets"

# 2. Google OAuth (Login with Google)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- AI PROVIDERS ---
# OpenAI (For text/prompt generation)
OPENAI_API_KEY="sk-proj-your-openai-api-key"

# Replicate / Runway / Luma (For Video Generation Models)
REPLICATE_API_TOKEN="r8_your_replicate_api_token"

# Anthropic (Optional)
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"

# Gemini (Google AI)
GEMINI_API_KEY="your-gemini-api-key"

# DeepSeek
DEEPSEEK_API_KEY="your-deepseek-api-key"

# Grok (xAI)
XAI_API_KEY="your-xai-api-key"

# Groq
GROQ_API_KEY="gsk_your-groq-api-key"

# Fal.ai
FAL_KEY="your-fal-key"
