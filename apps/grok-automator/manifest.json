{
  "manifest_version": 3,
  "name": "VidForge AI Automator",
  "version": "1.0",
  "description": "Tự động hóa luồng làm video với các AI như Grok.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://grok.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://grok.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
