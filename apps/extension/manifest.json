{
  "manifest_version": 3,
  "name": "VidForge AI",
  "version": "1.0.0",
  "description": "VidForge AI Content Extractor",
  "icons": {
    "16": "icon.jpg",
    "48": "icon.jpg",
    "128": "icon.jpg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VidForge AI",
    "default_icon": "icon.jpg"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://vidforge-ai.duckdns.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
